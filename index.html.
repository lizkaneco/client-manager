async function sbFetch(path, options = {}) {
  const res = await fetch(SUPABASE_URL + path, {
    ...options,
    headers: {
      "apikey": SUPABASE_KEY,
      "Authorization": "Bearer " + SUPABASE_KEY,
      "Content-Type": "application/json",
      "Prefer": options.prefer || "",
      ...(options.headers || {})
    }
  });
  if (!res.ok) { const t = await res.text(); throw new Error(t); }
  const text = await res.text();
  return text ? JSON.parse(text) : null;
}

async function loadFromSupabase() {
  try {
    const rows = await sbFetch("/rest/v1/clients?select=*&order=original_id.asc.nullslast,created_at.asc");
    return rows.map(r => ({
      id: r.original_id || r.id,
      supabase_id: r.id,
      name: r.name || "",
      city: r.city || "",
      address: r.address || "",
      phone: r.phone || "",
      neighborhood: r.neighborhood || "",
      status: r.status || "Customer",
      notes: r.notes || "",
      lastContact: r.last_contact || "",
      contact: r.contact_person || "",
      contacts: r.contacts || [],
      appointments: r.appointments || [],
    }));
  } catch(e) {
    console.error("Supabase load error:", e);
    return null;
  }
}

async function upsertToSupabase(client) {
  try {
    const payload = {
      name: client.name,
      city: client.city,
      address: client.address,
      phone: client.phone,
      neighborhood: client.neighborhood,
      status: client.status,
      notes: client.notes || "",
      last_contact: client.lastContact || "",
      contact_person: client.contact || "",
      contacts: client.contacts || [],
      appointments: client.appointments || [],
    };
    if (client.supabase_id) {
      await sbFetch("/rest/v1/clients?id=eq." + client.supabase_id, {
        method: "PATCH",
        prefer: "return=minimal",
        body: JSON.stringify(payload)
      });
    } else if (typeof client.id === "number" && client.id < 100000) {
      await sbFetch("/rest/v1/clients?original_id=eq." + client.id, {
        method: "PATCH",
        prefer: "return=minimal",
        body: JSON.stringify(payload)
      });
    }
  } catch(e) {
    console.error("Supabase upsert error:", e);
  }
}

async function insertClientToSupabase(client) {
  try {
    const payload = {
      original_id: null,
      name: client.name,
      city: client.city,
      address: client.address,
      phone: client.phone,
      neighborhood: client.neighborhood,
      status: client.status,
      notes: client.notes,
      last_contact: client.lastContact,
      contact_person: client.contact || "",
      contacts: client.contacts || [],
      appointments: client.appointments || [],
    };
    const rows = await sbFetch("/rest/v1/clients", {
      method: "POST",
      prefer: "return=representation",
      body: JSON.stringify(payload)
    });
    return rows?.[0];
  } catch(e) {
    console.error("Supabase insert error:", e);
    return null;
  }
}

