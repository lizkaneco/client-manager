                          <div className="lbl">{label}</div>
                          <input type={span === "date" ? "date" : "text"} className="ef" value={editForm[k] || ""}
                            onChange={e => setEditForm(f => ({ ...f, [k]: e.target.value }))} />
                        </div>
                      ))}
                      <div>
                        <div className="lbl">Status</div>
                        <select className="ef" value={editForm.status || "Customer"} onChange={e => setEditForm(f => ({ ...f, status: e.target.value }))}>
                          <option>Customer</option><option>Prospect</option>
                        </select>
                      </div>
                      <div style={{ gridColumn: "span 2" }}>
                        <div className="lbl">Notes</div>
                        <textarea className="ef" rows={2} value={editForm.notes || ""} onChange={e => setEditForm(f => ({ ...f, notes: e.target.value }))} placeholder="Add notes…" style={{ resize: "vertical" }} />
                      </div>
                    </div>
                    <div style={{ display: "flex", gap: 9 }}>
                      <button className="ef" style={{ background: "#8b6914", color: "#fff", border: "none", padding: "9px 20px", borderRadius: 5, cursor: "pointer", fontFamily: "'Josefin Sans'", fontSize: 11, letterSpacing: "0.1em", textTransform: "uppercase", width: "auto" }}
                        onClick={saveEdit}>Save</button>
                      <button className="ef" style={{ background: "transparent", color: MUTED, padding: "9px 16px", borderRadius: 5, cursor: "pointer", fontFamily: "'Josefin Sans'", fontSize: 11, letterSpacing: "0.1em", textTransform: "uppercase", width: "auto" }}
                        onClick={cancelEdit}>Cancel</button>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        );
      })}

      </div>
      {filtered.length === 0 && (
        <div style={{ padding: 60, textAlign: "center", fontFamily: "'Josefin Sans'", fontSize: 11, letterSpacing: "0.15em", textTransform: "uppercase", color: FAINT }}>No accounts found</div>
      )}
      <div style={{ height: 40 }} />

      {showAdd && (
        <div style={{ position: "fixed", inset: 0, zIndex: 200, display: "flex", alignItems: "flex-end", background: "rgba(0,0,0,0.75)" }}
          onClick={() => setShowAdd(false)}>
          <div style={{ background: "#161310", width: "100%", maxWidth: 700, margin: "0 auto", borderRadius: "16px 16px 0 0", padding: "20px 16px 36px", maxHeight: "90vh", overflowY: "auto" }}
            onClick={e => e.stopPropagation()}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <div style={{ fontFamily: "'Cormorant Garamond'", fontSize: 20, fontWeight: 600 }}>New Account</div>
              <button onClick={() => setShowAdd(false)} style={{ background: "transparent", border: "none", color: MUTED, fontSize: 22, cursor: "pointer" }}>&#x2715;</button>
            </div>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 14 }}>
              <div style={{ gridColumn: "span 2" }}>
                <div className="lbl">Name <span style={{ color: G }}>*</span></div>
                <input className="ef" value={addForm.name} onChange={e => setAddForm(f => ({ ...f, name: e.target.value }))} placeholder="Restaurant / business name" />
              </div>
              <div style={{ gridColumn: "span 2" }}>
                <div className="lbl">Contact Person</div>
                <input className="ef" value={addForm.contact||""} onChange={e => setAddForm(f => ({ ...f, contact: e.target.value }))} placeholder="Owner / Manager name" />
              </div>
              <div>
                <div className="lbl">Phone</div>
                <input className="ef" value={addForm.phone} onChange={e => setAddForm(f => ({ ...f, phone: e.target.value }))} />
              </div>
              <div>
                <div className="lbl">City</div>
                <input className="ef" value={addForm.city} onChange={e => setAddForm(f => ({ ...f, city: e.target.value }))} />
              </div>
              <div style={{ gridColumn: "span 2" }}>
                <div className="lbl">Address</div>
                <input className="ef" value={addForm.address} onChange={e => setAddForm(f => ({ ...f, address: e.target.value }))} />
              </div>
              <div>
                <div className="lbl">Neighborhood</div>
                <input className="ef" value={addForm.neighborhood} onChange={e => setAddForm(f => ({ ...f, neighborhood: e.target.value }))} />
              </div>
              <div>
                <div className="lbl">Status</div>
                <select className="ef" value={addForm.status} onChange={e => setAddForm(f => ({ ...f, status: e.target.value }))}>
                  <option>Customer</option><option>Prospect</option>
                </select>
              </div>
              <div>
                <div className="lbl">Last Contact</div>
                <input type="date" className="ef" value={addForm.lastContact} onChange={e => setAddForm(f => ({ ...f, lastContact: e.target.value }))} />
              </div>
              <div style={{ gridColumn: "span 2" }}>
                <div className="lbl">Notes</div>
                <textarea className="ef" rows={2} value={addForm.notes} onChange={e => setAddForm(f => ({ ...f, notes: e.target.value }))} placeholder="Optional..." style={{ resize: "vertical" }} />
              </div>
            </div>
            <div style={{ display: "flex", gap: 9 }}>
              <button onClick={saveAdd} disabled={!addForm.name.trim()}
                style={{ background: addForm.name.trim() ? G : FAINT, color: "#0a0806", border: "none", padding: "10px 22px", borderRadius: 6, fontFamily: "'Josefin Sans'", fontSize: 12, letterSpacing: "0.1em", textTransform: "uppercase", cursor: addForm.name.trim() ? "pointer" : "default", fontWeight: 700 }}>
                Save Account
              </button>
              <button onClick={() => setShowAdd(false)}
                style={{ background: "transparent", color: MUTED, border: "1px solid #3a2e1a", padding: "10px 18px", borderRadius: 6, fontFamily: "'Josefin Sans'", fontSize: 12, letterSpacing: "0.1em", textTransform: "uppercase", cursor: "pointer" }}>
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

  const root = ReactDOM.createRoot(document.getElementById('root'));
  root.render(<App />);
  </script>
</body>
</html>
