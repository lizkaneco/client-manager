// localStorage fallback while loading
function localLoad() {
  try {
    const raw = localStorage.getItem("client-mgr-v3");
    if (raw) {
      const saved = JSON.parse(raw);
      return RAW_CLIENTS.map(c => ({ ...c, contacts: [], appointments: [], ...(saved[c.id] || {}) }));
    }
  } catch {}
  return RAW_CLIENTS.map(c => ({ ...c, contacts: [], appointments: [] }));
}

const PALETTE = ["#c9a227","#0e7490","#be185d","#15803d","#7c3aed","#c2410c","#0369a1","#b91c1c","#4338ca","#0f766e","#b45309","#6d28d9"];

function App() {
  const [clients, setClients] = useState(localLoad);
  const [loading, setLoading] = useState(true);
  const [syncStatus, setSyncStatus] = useState("syncing"); // syncing | ok | error
  const [search, setSearch] = useState("");
  const [cityFilter, setCityFilter] = useState("All");
  const [nbhdFilter, setNbhdFilter] = useState("All");
  const [statusFilter, setStatusFilter] = useState("All");
  const [expandedId, setExpandedId] = useState(null);
  const [editingId, setEditingId] = useState(null);
  const [editForm, setEditForm] = useState({});

  const cities = useMemo(() => ["All", ...Array.from(new Set(clients.map(c => c.city))).sort()], [clients]);
  const colorMap = useMemo(() => {
    const m = {};
    cities.filter(c => c !== "All").forEach((c, i) => { m[c] = PALETTE[i % PALETTE.length]; });
    return m;
  }, [cities]);
  const neighborhoods = useMemo(() => {
    const base = clients.filter(c => cityFilter === "All" || c.city === cityFilter);
    return ["All", ...Array.from(new Set(base.map(c => c.neighborhood).filter(Boolean))).sort()];
  }, [clients, cityFilter]);

  const filtered = useMemo(() => {
    const q = search.toLowerCase();
    return clients.filter(c => {
      if (statusFilter !== "All" && c.status !== statusFilter) return false;
      if (cityFilter !== "All" && c.city !== cityFilter) return false;
      if (nbhdFilter !== "All" && c.neighborhood !== nbhdFilter) return false;
      if (q && ![c.name, c.address, c.phone, c.neighborhood, c.notes].some(v => v?.toLowerCase().includes(q))) return false;
      return true;
    });
  }, [clients, search, cityFilter, nbhdFilter, statusFilter]);

  const stats = useMemo(() => ({
    total: clients.length,
    customers: clients.filter(c => c.status === "Customer").length,
    prospects: clients.filter(c => c.status === "Prospect").length,
  }), [clients]);

  // Load from Supabase on mount
  useEffect(() => {
    loadFromSupabase().then(rows => {
      if (rows && rows.length > 0) {
        setClients(rows);
        setSyncStatus("ok");
      } else if (rows && rows.length === 0) {
        // First time - seed from RAW_CLIENTS
        setSyncStatus("seeding");
        const seed = RAW_CLIENTS.map(c => ({ ...c, contacts: [], appointments: [] }));
        Promise.all(seed.map(c => upsertToSupabase(c))).then(() => {
          loadFromSupabase().then(fresh => {
            if (fresh) setClients(fresh);
            setSyncStatus("ok");
            setLoading(false);
          });
        });
        return;
      } else {
        setSyncStatus("error");
      }
      setLoading(false);
    });
  }, []);

  const [showAdd, setShowAdd] = useState(false);
  const [addForm, setAddForm] = useState({ name: "", city: "", address: "", phone: "", neighborhood: "", status: "Customer", notes: "", lastContact: "" });
  const [contactForm, setContactForm] = useState({ name: "", role: "", phone: "", email: "" });
  const [addingContactFor, setAddingContactFor] = useState(null);
  const [apptForm, setApptForm] = useState({ date: "", time: "", note: "" });
  const [addingApptFor, setAddingApptFor] = useState(null);

  function toggle(id) { if (editingId !== id) setExpandedId(p => p === id ? null : id); }
  function startEdit(client, e) { e.stopPropagation(); setEditForm({ ...client }); setEditingId(client.id); setExpandedId(client.id); }
  function saveEdit(e) {
    e.stopPropagation();
    const updated = clients.find(c => c.id === editingId);
    const merged = { ...updated, ...editForm };
    setClients(p => p.map(c => c.id === editingId ? merged : c));
    setEditingId(null);
    upsertToSupabase(merged);
  }
  function cancelEdit(e) { e.stopPropagation(); setEditingId(null); }

  function openAdd() { setAddForm({ name: "", city: "", address: "", phone: "", neighborhood: "", status: "Customer", notes: "", lastContact: "" }); setShowAdd(true); }
  function saveAdd() {
    if (!addForm.name.trim()) return;
    const tempId = Date.now();
    const newClient = { ...addForm, id: tempId, contacts: [], appointments: [] };
    setClients(p => [newClient, ...p]);
    setShowAdd(false);
    setExpandedId(tempId);
    insertClientToSupabase(newClient).then(row => {
      if (row) {
        setClients(p => p.map(c => c.id === tempId ? { ...c, supabase_id: row.id } : c));
      }
    });
  }

  function addContact(clientId) {
    if (!contactForm.name.trim()) return;
    const newContact = { ...contactForm, id: Date.now() };
    setClients(p => p.map(c => {
      if (c.id !== clientId) return c;
      const contacts = [...(c.contacts || []), newContact];
      const updated = { ...c, contacts };
      upsertToSupabase(updated);
      return updated;
    }));
    setContactForm({ name: "", role: "", phone: "", email: "" });
    setAddingContactFor(null);
  }

  function removeContact(clientId, contactId) {
    setClients(p => p.map(c => {
      if (c.id !== clientId) return c;
      const contacts = (c.contacts || []).filter(ct => ct.id !== contactId);
      const updated = { ...c, contacts };
      upsertToSupabase(updated);
      return updated;
    }));
  }

  function addAppt(clientId) {
    if (!apptForm.date) return;
    const newAppt = { ...apptForm, id: Date.now() };
    setClients(p => p.map(c => {
      if (c.id !== clientId) return c;
      const appointments = [...(c.appointments || []), newAppt].sort((a,b) => a.date.localeCompare(b.date));
      const updated = { ...c, appointments };
      upsertToSupabase(updated);
      return updated;
    }));
    setApptForm({ date: "", time: "", note: "" });
    setAddingApptFor(null);
  }

  function removeAppt(clientId, apptId) {
    setClients(p => p.map(c => {
      if (c.id !== clientId) return c;
      const appointments = (c.appointments || []).filter(a => a.id !== apptId);
      const updated = { ...c, appointments };
      upsertToSupabase(updated);
      return updated;
    }));
  }

  const upcomingAppts = useMemo(() => {
    const today = new Date(); today.setHours(0,0,0,0);
    const cutoff = new Date(today); cutoff.setDate(today.getDate() + 7);
    const list = [];
    clients.forEach(c => {
      (c.appointments || []).forEach(a => {
        const d = new Date(a.date + "T00:00:00");
        if (d >= today && d <= cutoff) list.push({ ...a, clientName: c.name, clientId: c.id, clientCity: c.city });
      });
    });
    return list.sort((a,b) => a.date.localeCompare(b.date));
  }, [clients]);

  const G = "#c9a227", BG = "#0f0d0a", CARD = "#161310", BORDER = "#252010", MUTED = "#6b5530", TEXT = "#e8dcc8", FAINT = "#3a2e1a";

